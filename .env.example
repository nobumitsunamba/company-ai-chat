# ──────────────────────────────────────────
# 必須：Anthropic API Key
# https://console.anthropic.com/ で取得
# ──────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ──────────────────────────────────────────
# 任意：Vercel KV（Upstash Redis）
#
# Vercel Dashboard で KV を作成しプロジェクトに
# リンクすると以下が自動設定されます。
# ローカル開発時は「vercel env pull .env.local」
# で取得するか、Upstash Console で手動作成して
# 以下に貼り付けてください。
#
# 未設定時はインメモリ（起動中のみ有効）にフォールバック。
# クライアント localStorage で文書が保持されるため
# チャットは正常に動作します。
# ──────────────────────────────────────────
# KV_URL=redis://default:xxxx@xxxx.upstash.io:6379
# KV_REST_API_URL=https://xxxx.upstash.io
# KV_REST_API_TOKEN=xxxx
# KV_REST_API_READ_ONLY_TOKEN=xxxx
